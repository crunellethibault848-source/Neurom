# ──────────────────────────────────────────────────────────────
#  NEUROM — variables d'environnement
#  Copiez ce fichier en ".env.local" et remplissez vos clés Supabase.
#  (Settings → API dans votre dashboard Supabase)
#  Sur Vercel : ajoutez-les dans Project Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# URL publique du site (utile pour les redirections d'auth).
# En local: http://localhost:3000 — en prod: https://votre-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
